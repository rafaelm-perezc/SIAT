<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIAT - Terminal de La Plata</title>
    <link rel="stylesheet" href="../../assets/css/style.css">
</head>
<body class="flex items-center justify-center min-h-screen">
    
    <div class="text-center bg-terminal-darkgray p-10 rounded-xl shadow-2xl border-t-4 border-terminal-yellow">
        <h1 class="text-4xl font-bold mb-4">SIAT <span class="text-terminal-yellow">Terminal</span></h1>
        
        <p id="status" class="text-lg text-gray-400 font-medium">Verificando conexión con el motor...</p>
        
        <p class="mt-6 text-sm text-gray-500">Versión del Sistema: <%= appVersion %></p>
    </div>

    <script>
        // Consumimos el puente seguro que definimos en preload.js
        async function probarConexion() {
            try {
                const respuesta = await window.api.ping();
                const statusEl = document.getElementById('status');
                statusEl.innerText = respuesta;
                statusEl.classList.remove('text-gray-400');
                statusEl.classList.add('text-green-400'); // Si funciona, se pone verde
            } catch (error) {
                console.error("Error IPC:", error);
                document.getElementById('status').innerText = 'Error crítico de conexión';
            }
        }
        
        probarConexion();
    </script>
</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <title>SIAT - Configuración</title>
    <%- include('../partials/head.ejs') %>
    <script src="../../../assets/js/app.js" defer></script>
    <script src="../../../assets/js/configuracion/cargos.js" defer></script>
    <script src="../../../assets/js/configuracion/usuarios.js" defer></script>
</head>
<body class="bg-terminal-black flex h-screen overflow-hidden text-terminal-gray font-sans">
    
    <%- include('../partials/sidebar.ejs', { activeSection: 'configuracion' }) %>
    
    <main class="flex-1 flex flex-col h-screen overflow-hidden relative">
        <%- include('../partials/header.ejs') %>
        
        <div class="flex-1 overflow-y-auto p-8">
            
            <div class="flex justify-between items-center mb-6 border-b border-gray-800 pb-4">
                <div>
                    <h2 class="text-2xl font-bold text-white">Configuración del Sistema</h2>
                    <p class="text-sm text-gray-400">Gestión de estructura organizacional y permisos</p>
                </div>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
                
                <div class="bg-terminal-darkgray rounded-xl border border-gray-800 shadow-2xl p-6 flex flex-col h-[calc(100vh-220px)]">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-bold text-terminal-yellow flex items-center gap-2">
                            <span>👔</span> Catálogo de Cargos
                        </h3>
                        <button id="btnNuevoCargo" class="px-4 py-2 bg-green-600 text-white font-bold rounded hover:bg-green-500 transition-all shadow text-sm">
                            + Crear Cargo
                        </button>
                    </div>

                    <div class="overflow-y-auto flex-1 border border-gray-700 rounded-lg">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-black text-gray-400 border-b border-gray-700 text-xs sticky top-0">
                                    <th class="p-3 font-semibold uppercase">Cargo</th>
                                    <th class="p-3 font-semibold uppercase">Descripción</th>
                                    <th class="p-3 font-semibold uppercase text-center w-32">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tablaCargos" class="divide-y divide-gray-800 text-sm text-gray-300 bg-terminal-darkgray">
                                <tr><td colspan="3" class="p-8 text-center text-gray-500 italic">Cargando datos...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="bg-terminal-darkgray rounded-xl border border-gray-800 shadow-2xl p-6 flex flex-col h-[calc(100vh-220px)]">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-bold text-blue-400 flex items-center gap-2">
                            <span>🔐</span> Accesos y Usuarios
                        </h3>
                        <button id="btnNuevoUsuario" class="px-4 py-2 bg-blue-600 text-white font-bold rounded hover:bg-blue-500 transition-all shadow text-sm">
                            + Asignar Acceso
                        </button>
                    </div>

                    <div class="overflow-y-auto flex-1 border border-gray-700 rounded-lg">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-black text-gray-400 border-b border-gray-700 text-xs sticky top-0">
                                    <th class="p-3 font-semibold uppercase">Empleado</th>
                                    <th class="p-3 font-semibold uppercase">Rol</th>
                                    <th class="p-3 font-semibold uppercase">Cargo Base</th>
                                    <th class="p-3 font-semibold uppercase text-center">Estado</th>
                                    <th class="p-3 font-semibold uppercase text-center w-32">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tablaUsuarios" class="divide-y divide-gray-800 text-sm text-gray-300 bg-terminal-darkgray">
                                <tr><td colspan="5" class="p-8 text-center text-gray-500 italic">Cargando datos...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </main>
</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>SIAT - Inicio de Sesión</title>
    <link rel="stylesheet" href="../../../assets/css/style.css">
    <script src="../../../node_modules/sweetalert2/dist/sweetalert2.all.min.js"></script>
    <script src="../../../assets/js/auth/login.js" defer></script>
</head>
<body class="bg-terminal-black flex items-center justify-center min-h-screen">

    <div class="w-full max-w-md p-8 bg-terminal-darkgray rounded-2xl shadow-2xl border-b-4 border-terminal-yellow">
        <div class="text-center mb-8">
            <h1 class="text-4xl font-bold text-terminal-gray italic">SIAT</h1>
            <p class="text-sm text-gray-400 mt-2">Sistema Inteligente de Asignación de Turnos</p>
        </div>

        <form id="loginForm" class="space-y-6">
            <div>
                <label class="block text-sm font-medium mb-2 text-terminal-gray">Usuario</label>
                <input type="text" id="usuario" required
                    class="w-full px-4 py-3 bg-black border border-gray-700 rounded-lg focus:outline-none focus:border-terminal-yellow text-white transition-colors">
            </div>

            <div>
                <label class="block text-sm font-medium mb-2 text-terminal-gray">Contraseña</label>
                <input type="password" id="password" required
                    class="w-full px-4 py-3 bg-black border border-gray-700 rounded-lg focus:outline-none focus:border-terminal-yellow text-white transition-colors">
            </div>

            <button type="submit" 
                class="w-full py-3 bg-terminal-yellow text-black font-bold rounded-lg hover:bg-yellow-500 transition-all transform hover:scale-[1.02] active:scale-95">
                INGRESAR AL SISTEMA
            </button>
        </form>
    </div>

</body>
</html>
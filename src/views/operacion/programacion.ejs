<!DOCTYPE html>
<html lang="es">
<head>
    <title>SIAT - Planilla de Programación</title>
    <%- include('../partials/head.ejs') %>
    <script src="../../../assets/js/app.js" defer></script>
    <script src="../../../assets/js/operacion/programacion.js" defer></script>
</head>
<body class="bg-terminal-black flex h-screen overflow-hidden text-terminal-gray font-sans">
    
    <%- include('../partials/sidebar.ejs', { activeSection: 'programacion' }) %>
    
    <main class="flex-1 flex flex-col h-screen overflow-hidden relative">
        <%- include('../partials/header.ejs') %>
        
        <div class="flex-1 p-6 flex flex-col overflow-hidden">
            
            <div class="flex justify-between items-center mb-4 border-b border-gray-800 pb-4 shrink-0">
                <div>
                    <h2 class="text-2xl font-bold text-white flex items-center gap-2">🗓️ Planilla de Turnos (Matriz)</h2>
                    <p class="text-sm text-gray-400">Programación operativa dinámica mensual</p>
                </div>
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2 bg-black border border-gray-700 rounded-lg px-3 py-2">
                        <label class="text-xs text-terminal-yellow font-bold uppercase">Mes a programar:</label>
                        <input type="month" id="filtroMes" class="bg-transparent text-white text-sm outline-none cursor-pointer" style="color-scheme: dark;">
                        <button id="btnCargarMatriz" class="ml-3 px-3 py-1 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded text-xs transition-colors">Cargar</button>
                    </div>
                    <button id="btnAutoGenerar" class="px-4 py-2 bg-purple-700 hover:bg-purple-600 text-white font-bold rounded-lg transition-all shadow-[0_0_10px_rgba(126,34,206,0.5)] flex items-center gap-2">
                        <span>🤖</span> Auto-Generar Mes
                    </button>
                </div>
            </div>

            <div class="bg-terminal-darkgray rounded-xl border border-gray-800 shadow-2xl flex-1 flex flex-col overflow-hidden">
                <div class="overflow-auto flex-1 custom-scrollbar relative">
                    <table class="w-max min-w-full text-left border-collapse border-spacing-0">
                        <thead id="tablaCabeceraDias" class="sticky top-0 z-20 shadow-md bg-black">
                            </thead>
                        <tbody id="tablaMatriz" class="divide-y divide-gray-800 text-xs text-gray-300">
                            <tr><td class="p-8 text-center text-gray-500 italic">Seleccione un mes y cargue la planilla.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <%- include('../partials/footer.ejs') %>
    </main>
    
</body>
</html>
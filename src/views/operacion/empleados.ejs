<!DOCTYPE html>
<html lang="es">
<head>
    <title>SIAT - Personal Operativo</title>
    <%- include('../partials/head') %>
    <script src="../../../assets/js/operacion/empleados.js" defer></script>
</head>
<body class="bg-terminal-black flex h-screen overflow-hidden text-terminal-gray font-sans">

    <%- include('../partials/sidebar', { activeSection: 'empleados' }) %>

    <main class="flex-1 flex flex-col h-screen overflow-hidden relative">
        <%- include('../partials/header') %>

        <div class="flex-1 overflow-y-auto p-8">
            <div class="flex justify-between items-center mb-6 border-b border-gray-800 pb-4">
                <div>
                    <h2 class="text-2xl font-bold text-white">Directorio de Personal</h2>
                    <p class="text-sm text-gray-400">Gestión de operarios y carga masiva</p>
                </div>
                <div class="flex gap-4">
                    <button id="btnModalExcel" class="px-5 py-2.5 bg-green-600 text-white font-bold rounded-lg hover:bg-green-500 transition-all shadow-lg flex items-center gap-2">
                        <span>📊</span> Carga Masiva
                    </button>
                    <button id="btnRegistroManual" class="px-5 py-2.5 bg-terminal-yellow text-black font-bold rounded-lg hover:bg-yellow-500 flex items-center gap-2">
                        <span>➕</span> Registro Manual
                    </button>
                </div>
            </div>

            <div class="bg-terminal-darkgray rounded-xl border border-gray-800 overflow-hidden shadow-2xl">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-black text-terminal-yellow border-b border-gray-700 text-sm">
                            <th class="p-4 font-semibold uppercase tracking-wider">Documento</th>
                            <th class="p-4 font-semibold uppercase tracking-wider">Apellidos y Nombres</th>
                            <th class="p-4 font-semibold uppercase tracking-wider">Cargo</th>
                            <th class="p-4 font-semibold uppercase tracking-wider text-center">Contrato</th>
                            <th class="p-4 font-semibold uppercase tracking-wider text-center">Estado</th>
                            <th class="p-4 font-semibold uppercase tracking-wider text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tablaEmpleados" class="divide-y divide-gray-800 text-sm text-gray-300">
                        <tr><td colspan="6" class="p-8 text-center text-gray-500 italic">Cargando datos...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <title>SIAT - Zonas de Operación</title>
    <%- include('../partials/head.ejs') %>
    <script src="../../../assets/js/app.js" defer></script>
    <script src="../../../assets/js/operacion/zonas.js" defer></script>
</head>
<body class="bg-terminal-black flex h-screen overflow-hidden text-terminal-gray font-sans">
    
    <%- include('../partials/sidebar.ejs', { activeSection: 'zonas' }) %>
    
    <main class="flex-1 flex flex-col h-screen overflow-hidden relative">
        <%- include('../partials/header.ejs') %>
        
        <div class="flex-1 overflow-y-auto p-8">
            
            <div class="flex justify-between items-center mb-6 border-b border-gray-800 pb-4">
                <div>
                    <h2 class="text-2xl font-bold text-white">Zonas de la Terminal</h2>
                    <p class="text-sm text-gray-400">Gestión de áreas físicas y requerimientos de personal operativo</p>
                </div>
                <button id="btnNuevaZona" class="px-5 py-2.5 bg-green-600 text-white font-bold rounded-lg hover:bg-green-500 transition-all shadow-lg flex items-center gap-2">
                    <span>➕</span> Registrar Zona
                </button>
            </div>

            <div class="bg-terminal-darkgray rounded-xl border border-gray-800 overflow-hidden shadow-2xl w-full max-w-5xl mt-8">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-black text-terminal-yellow border-b border-gray-700 text-sm">
                            <th class="p-4 font-semibold uppercase tracking-wider w-16 text-center">ID</th>
                            <th class="p-4 font-semibold uppercase tracking-wider">Nombre de la Zona</th>
                            <th class="p-4 font-semibold uppercase tracking-wider text-center">Personal Requerido (Por Turno)</th>
                            <th class="p-4 font-semibold uppercase tracking-wider text-center w-32">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tablaZonas" class="divide-y divide-gray-800 text-sm text-gray-300">
                        <tr><td colspan="4" class="p-8 text-center text-gray-500 italic">Cargando datos...</td></tr>
                    </tbody>
                </table>
            </div>

        </div>
    </main>
</body>
</html>
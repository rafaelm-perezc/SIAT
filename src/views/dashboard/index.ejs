<!DOCTYPE html>
<html lang="es">
<head>
    <title>SIAT - Dashboard</title>
    <%- include('../partials/head.ejs') %>
    <script src="../../../assets/js/app.js" defer></script>
    <script src="../../../assets/js/dashboard/index.js" defer></script> 
</head>
<body class="bg-terminal-black flex h-screen overflow-hidden text-terminal-gray font-sans">

    <%- include('../partials/sidebar.ejs', { activeSection: 'dashboard' }) %>

    <main class="flex-1 flex flex-col h-screen overflow-hidden relative">
        
        <%- include('../partials/header.ejs') %>

        <div class="flex-1 overflow-y-auto p-8">
            
            <div class="mb-6">
                <h2 class="text-2xl font-bold text-white">Centro de Mando Operativo</h2>
                <p class="text-sm text-gray-400">Resumen de capacidad y métricas de nómina en tiempo real.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
                
                <div class="bg-terminal-darkgray p-5 rounded-xl border-l-4 border-terminal-yellow shadow-lg flex flex-col justify-between">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider">Personal Operativo</h3>
                    <p id="statOperativos" class="text-3xl font-bold text-white mt-2">...</p>
                </div>
                
                <div class="bg-terminal-darkgray p-5 rounded-xl border-l-4 border-blue-500 shadow-lg flex flex-col justify-between">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider">Zonas Activas</h3>
                    <p id="statZonas" class="text-3xl font-bold text-white mt-2">...</p>
                </div>

                <div class="bg-terminal-darkgray p-5 rounded-xl border-l-4 border-green-500 shadow-lg flex flex-col justify-between">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider">Turnos Asignados (Hoy)</h3>
                    <p id="statTurnosHoy" class="text-3xl font-bold text-white mt-2">...</p>
                </div>

                <div class="bg-terminal-darkgray p-5 rounded-xl border-l-4 border-red-500 shadow-lg flex flex-col justify-between">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider">Horas Extras (Mes)</h3>
                    <p id="statHorasExtras" class="text-3xl font-bold text-red-400 mt-2">...</p>
                </div>

                <div class="bg-terminal-darkgray p-5 rounded-xl border-l-4 border-purple-500 shadow-lg flex flex-col justify-between">
                    <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider">Jornada Ley 2101</h3>
                    <p id="statJornada" class="text-3xl font-bold text-purple-400 mt-2">...</p>
                </div>

            </div>

            <div class="bg-terminal-darkgray rounded-xl p-8 border border-gray-800 min-h-[300px] flex flex-col items-center justify-center">
                <span class="text-6xl mb-4">📊</span>
                <h3 class="text-2xl font-bold text-white">Sistema Integrado de Asignación de Turnos</h3>
                <p class="text-gray-500 mt-2 text-center max-w-lg">El motor de Inteligencia Operativa está configurado. Dirígete a la "Planilla de Programación" para generar la rotación automática del mes.</p>
            </div>
        </div>
        
        <%- include('../partials/footer.ejs') %>
    </main>
    
</body>
</html>